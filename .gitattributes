* text=auto eol=lf

# Python source
*.py      text eol=lf diff=python
*.pyi     text eol=lf diff=python
*.pyw     text eol=lf diff=python

# Project configuration
*.toml    text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf

# Documentation and diagrams
*.md      text eol=lf
*.txt     text eol=lf
*.puml    text eol=lf
*.plantuml text eol=lf

# Scripts
*.ps1     text eol=lf
*.sh      text eol=lf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Images and generated diagram outputs
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.svg     text eol=lf
*.pdf     binary

# Archives and packaged artifacts
*.zip     binary
*.7z      binary
*.rar     binary
*.tar     binary
*.gz      binary
